# Copy to .env (local) or set in Render/Railway dashboard (production)
INZIRA_ENV=development

# ── AI Assistant ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Database ─────────────────────────────────────────────────
# Local: SQLite (default if unset)
# DATABASE_URL=sqlite:///./inzira_local.db
# Production: PostgreSQL (Render adds postgres:// — auto-normalized)
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/inzira

# ── Firebase ───────────────────────────────────────────────────
INZIRA_FIREBASE_PROJECT_ID=inzira-52474
# Optional: account deletion + admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── CORS (REQUIRED in production — your live domain) ─────────
# CORS_ORIGINS=https://inzira.onrender.com,https://www.yourdomain.rw
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── MIFOTRA staff portal ───────────────────────────────────────
INZIRA_MIFOTRA_EMAIL_DOMAINS=mifotra.gov.rw
INZIRA_MIFOTRA_STAFF_PASSWORD=choose_a_strong_password_for_ministry_staff

# Android APK download (optional — or place file at web/downloads/inzira.apk)
# INZIRA_APK_URL=https://your-cdn.example.com/inzira.apk

# ── Web Push (generate: python scripts/generate_vapid_keys.py) ─
INZIRA_VAPID_PUBLIC_KEY=
INZIRA_VAPID_PRIVATE_KEY=
INZIRA_VAPID_CLAIMS_EMAIL=mailto:alerts@inzira.rw

# ── Deploy assets (models + registry.db zip URL) ───────────────
# Package: .\scripts\package_deploy_assets.ps1 → upload zip → paste link
# Google Drive share links work (must be "Anyone with the link")
INZIRA_ASSETS_BUNDLE_URL=

# ── Admin users (comma-separated emails) ─────────────────────
INZIRA_ADMIN_EMAILS=

# ── Optional ───────────────────────────────────────────────────
RATE_LIMIT_MAX_PER_MIN=120
ALERT_SCAN_INTERVAL_MINUTES=30
# INZIRA_DISABLE_ALERT_SCHEDULER=1
