[Unit]
Description=Inzira Youth Opportunity Platform
After=network.target

[Service]
Type=simple
User=__INZIRA_USER__
WorkingDirectory=__INZIRA_ROOT__
EnvironmentFile=__INZIRA_ROOT__/.env
ExecStart=__INZIRA_ROOT__/.venv/bin/python -m uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
