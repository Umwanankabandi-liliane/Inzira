<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">

            <TextView
                android:id="@+id/tvMatchScore"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="87%" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMatchLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Match fit"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.06" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Mastercard Foundation Scholars" />

            <TextView
                android:id="@+id/tvUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                tools:text="mastercardfdn.org" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTrustScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_dark_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Trust 92%" />

            <TextView
                android:id="@+id/tvCompetition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:visibility="gone"
                tools:text="High competition"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/matchBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="87"
        android:progressDrawable="@drawable/match_progress_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/badge_blue_text"
            android:textSize="10sp"
            tools:text="Scholarship" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvMatchTier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/success_green"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Strong match" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvWhyFitTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Why you fit"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvWhyFit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_trust_box"
        android:lineSpacingExtra="3dp"
        android:padding="10dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        tools:text="• Matches your interest in technology\n• Relevant to Gasabo" />

    <TextView
        android:id="@+id/btnVisit"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_btn_outline_blue"
        android:gravity="center"
        android:text="Visit website"
        android:textColor="@color/medium_blue"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
