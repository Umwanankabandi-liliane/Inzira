# Copy to keystore.properties (never commit the real file).
# Generate keystore:
#   keytool -genkey -v -keystore inzira-release.keystore -alias inzira -keyalg RSA -keysize 2048 -validity 10000

storeFile=../inzira-release.keystore
storePassword=your_store_password
keyAlias=inzira
keyPassword=your_key_password
